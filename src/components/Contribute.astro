---
interface Props {
  title: string;
  intro: string;
  body: string;
  ctaLabel: string;
  ctaHref: string;
}

const { title, intro, body, ctaLabel, ctaHref } = Astro.props;
---

<section
  class="py-16 bg-surface-container-low relative overflow-hidden text-on-surface"
  id="ayuda"
>
  <div class="absolute top-0 left-0 w-full h-24 mandala-watermark opacity-10">
  </div>
  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <div class="text-center mb-12">
      <h2
        class="text-5xl font-headline font-bold text-primary tracking-tight"
      >
        {title}
      </h2>
      <p class="text-on-surface-variant max-w-2xl mx-auto mt-4">{intro}</p>
    </div>
    <div class="max-w-3xl mx-auto">
      <div
        class="bg-surface rounded-[2.5rem] p-10 md:p-12 shadow-xl border border-outline-variant/5"
      >
        <p class="text-on-surface leading-relaxed mb-8" set:html={body} />
        <a
          class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-8 py-4 text-on-primary font-bold text-sm uppercase tracking-widest shadow-lg transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary/90 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-surface"
          href={ctaHref}
          target="_blank"
          rel="noopener noreferrer"
        >
          {ctaLabel} <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
