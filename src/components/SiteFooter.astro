---
interface Props {
  logoUrl?: string;
  creditPrefix: string;
  creditLinkLabel: string;
  creditLinkHref: string;
}

const {
  logoUrl = "/batweania-logo.png",
  creditPrefix,
  creditLinkLabel,
  creditLinkHref,
} = Astro.props;
---

<footer class="w-full bg-brand-dark text-brand-cream py-12">
  <div
    class="flex flex-col items-center gap-4 px-6 text-center max-w-7xl mx-auto"
  >
    <div class="mb-2 flex justify-center w-full">
      <img
        src={logoUrl}
        alt="Batwe Ania Parque Natural"
        width="1000"
        height="1000"
        decoding="async"
        class="h-auto w-full max-w-[220px] sm:max-w-[260px] object-contain drop-shadow-lg"
      />
    </div>
    <p class="font-label text-sm tracking-wide text-primary-fixed-dim">
      {creditPrefix}{" "}
      <a
        class="underline hover:text-tertiary transition-colors"
        href={creditLinkHref}
        target="_blank"
        rel="noopener"
      >
        {creditLinkLabel}
      </a>
    </p>
  </div>
</footer>
