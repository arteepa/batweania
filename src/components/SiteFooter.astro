---
import MaterialIcon from "./MaterialIcon.astro";

interface Props {
  siteName: string;
  logoIcon: string;
  creditPrefix: string;
  creditLinkLabel: string;
  creditLinkHref: string;
}

const { siteName, logoIcon, creditPrefix, creditLinkLabel, creditLinkHref } =
  Astro.props;
---

<footer class="w-full bg-brand-dark text-brand-cream py-12">
  <div
    class="flex flex-col items-center gap-4 px-6 text-center max-w-7xl mx-auto"
  >
    <div class="flex items-center gap-3">
      <MaterialIcon name={logoIcon} class="text-secondary text-4xl" />
      <span class="font-headline text-2xl italic text-[#616133]">
        {siteName}
      </span>
    </div>
    <p class="font-label text-sm tracking-wide uppercase text-[#594f3f]">
      {creditPrefix}{" "}
      <a
        class="underline hover:text-tertiary transition-colors"
        href={creditLinkHref}
        target="_blank"
        rel="noopener"
      >
        {creditLinkLabel}
      </a>
    </p>
  </div>
</footer>
