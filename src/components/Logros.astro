---
import MaterialIcon from "./MaterialIcon.astro";

interface Props {
  title: string;
  intro: string;
  items: string[];
}

const { title, intro, items } = Astro.props;
---

<section class="py-16 bg-brand-cream text-on-surface" id="logros">
  <div class="max-w-7xl mx-auto px-8">
    <div class="max-w-3xl mb-12">
      <h2
        class="text-5xl font-headline font-bold text-primary mb-4 tracking-tight"
      >
        {title}
      </h2>
      <p class="text-on-surface-variant text-lg">{intro}</p>
    </div>
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-6 list-none p-0 m-0">
      {
        items.map((item) => (
          <li class="bg-surface-container-high rounded-full p-8 flex gap-4 items-start border border-outline-variant/10 shadow-sm">
            <MaterialIcon
              name="check_circle"
              class="text-tertiary shrink-0 text-2xl mt-0.5"
            />
            <span class="text-on-surface leading-relaxed">{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
