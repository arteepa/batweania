---
interface Props {
  title: string;
  intro: string;
  instagramUrl: string;
  instagramHandle: string;
}

const { title, intro, instagramUrl, instagramHandle } = Astro.props;
---

<section
  class="py-16 bg-surface-container-high relative overflow-hidden text-on-surface"
  id="contacto"
>
  <div
    class="max-w-7xl mx-auto px-8 flex flex-col items-center text-center"
  >
    <div class="space-y-8 max-w-2xl">
      <h2
        class="text-5xl font-headline font-bold text-primary tracking-tight"
      >
        {title}
      </h2>
      <p class="text-on-surface-variant text-lg leading-relaxed">{intro}</p>
      <div class="space-y-6">
        <div class="flex justify-center items-start gap-4">
          <div>
            <a
              href={instagramUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-2 inline-flex items-center justify-center gap-2 rounded-full bg-primary px-8 py-4 text-on-primary font-bold text-sm uppercase tracking-widest shadow-lg transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary/90 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-surface"
            >
              Instagram<br />
              {instagramHandle} <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
