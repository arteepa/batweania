---
import MaterialIcon from "./MaterialIcon.astro";

interface Props {
  title: string;
  intro: string;
  locationLabel: string;
  locationText: string;
  emailLabel: string;
  emailAddress: string;
}

const {
  title,
  intro,
  locationLabel,
  locationText,
  emailLabel,
  emailAddress,
} = Astro.props;
---

<section
  class="py-16 bg-surface-container-high relative overflow-hidden"
  id="contacto"
>
  <div class="max-w-7xl mx-auto px-8">
    <div class="space-y-8 max-w-2xl">
      <h2
        class="text-5xl font-headline font-bold text-primary tracking-tight"
      >
        {title}
      </h2>
      <p class="text-on-surface-variant text-lg leading-relaxed">{intro}</p>
      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <MaterialIcon name="location_on" class="text-tertiary" />
          <div>
            <p class="font-bold text-primary">{locationLabel}</p>
            <p class="text-on-surface-variant">{locationText}</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <MaterialIcon name="mail" class="text-tertiary" />
          <div>
            <p class="font-bold text-primary">{emailLabel}</p>
            <p class="text-on-surface-variant">{emailAddress}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
