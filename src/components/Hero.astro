---
interface CTA {
  label: string;
  href: string;
}

interface Props {
  subtitle: string;
  primaryCta: CTA;
  secondaryCta: CTA;
  logoUrl?: string;
}

const {
  subtitle,
  primaryCta,
  secondaryCta,
  logoUrl = "/batweania-logo.png",
} = Astro.props;
---

<section
  class="relative flex items-center py-12 overflow-hidden text-brand-cream"
>
  <div
    class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10"
  >
    <div class="lg:col-span-6 lg:col-start-4">
      <div class="mb-4 flex justify-center w-full">
        <img
          src={logoUrl}
          alt="Batwe Ania Parque Natural"
          width="1000"
          height="1000"
          decoding="async"
          class="h-auto w-full max-w-[220px] sm:max-w-[260px] object-contain drop-shadow-lg"
        />
      </div>
      <p
        class="text-lg md:text-1xl text-brand-cream text-center leading-relaxed"
        set:html={subtitle}
      />
      <div
        class="flex flex-col sm:flex-row flex-wrap gap-6 pt-4 justify-center sm:items-center"
      >
        <a
          class="block w-full sm:w-auto text-center px-10 py-5 bg-brand-cream text-brand-dark rounded-full font-label font-bold text-sm uppercase tracking-widest hover:scale-105 transition-transform shadow-2xl"
          href={primaryCta.href}
        >
          {primaryCta.label}
        </a>
        <a
          class="block w-full sm:w-auto text-center px-10 py-5 border border-brand-cream/30 text-brand-cream rounded-full font-label font-bold text-sm uppercase tracking-widest hover:bg-white/10 transition-all"
          href={secondaryCta.href}
        >
          {secondaryCta.label}
        </a>
      </div>
    </div>
  </div>
</section>
