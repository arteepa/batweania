---
interface CTA {
  label: string;
  href: string;
}

interface Props {
  titlePlain: string;
  titleItalic: string;
  subtitle: string;
  primaryCta: CTA;
  secondaryCta: CTA;
}

const { titlePlain, titleItalic, subtitle, primaryCta, secondaryCta } =
  Astro.props;
---

<section
  class="relative flex items-center pb-12 pt-20 overflow-hidden bg-brand-dark text-brand-cream"
>
  <div
    class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10"
  >
    <div class="lg:col-span-6">
      <div class="mb-4">
        <h1
          class="text-4xl font-headline font-bold text-white leading-[0.9] mb-2"
        >
          {titlePlain}
          <br />
        </h1>
        <span
          class="text-7xl font-headline font-bold leading-[0.9] tracking-tighter italic text-tertiary-fixed"
        >
          {titleItalic}
        </span>
      </div>
      <p
        class="text-lg md:text-xl text-brand-cream/80 font-light max-w-lg leading-relaxed whitespace-pre-line"
      >
        {subtitle}
      </p>
      <div class="flex flex-wrap gap-6 pt-4">
        <a
          class="px-10 py-5 bg-brand-cream text-brand-dark rounded-full font-label font-bold text-sm uppercase tracking-widest hover:scale-105 transition-transform shadow-2xl"
          href={primaryCta.href}
        >
          {primaryCta.label}
        </a>
        <a
          class="px-10 py-5 border border-brand-cream/30 text-brand-cream rounded-full font-label font-bold text-sm uppercase tracking-widest hover:bg-white/10 transition-all"
          href={secondaryCta.href}
        >
          {secondaryCta.label}
        </a>
      </div>
    </div>
  </div>
</section>
