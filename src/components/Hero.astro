---
import MaterialIcon from "./MaterialIcon.astro";

interface CTA {
  label: string;
  href: string;
}

interface FloatingCard {
  icon: string;
  title: string;
  body: string;
}

interface Props {
  badgeIcon: string;
  badgeText: string;
  titlePlain: string;
  titleItalic: string;
  subtitle: string;
  primaryCta: CTA;
  secondaryCta: CTA;
  heroImageUrl: string;
  heroImageAlt: string;
  floatingCard: FloatingCard;
}

const {
  badgeIcon,
  badgeText,
  titlePlain,
  titleItalic,
  subtitle,
  primaryCta,
  secondaryCta,
  heroImageUrl,
  heroImageAlt,
  floatingCard,
} = Astro.props;
---

<section
  class="relative min-h-[795px] flex items-center pt-20 overflow-hidden bg-brand-dark text-brand-cream"
>
  <div class="absolute inset-0 woven-pattern opacity-5"></div>
  <div
    class="absolute -right-20 top-20 w-96 h-96 mandala-watermark opacity-10 rotate-12"
  >
  </div>
  <div
    class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10"
  >
    <div class="lg:col-span-6 space-y-8">
      <div
        class="inline-flex items-center gap-2 px-4 py-1.5 bg-tertiary-fixed text-on-tertiary-fixed rounded-full text-xs font-label font-bold uppercase tracking-widest"
      >
        <MaterialIcon name={badgeIcon} class="text-base" />
        {badgeText}
      </div>
      <h1
        class="text-6xl md:text-8xl font-headline font-bold text-white leading-[0.9] tracking-tighter"
      >
        {titlePlain}<br />
        <span class="italic text-tertiary-fixed">{titleItalic}</span>
      </h1>
      <p
        class="text-xl md:text-2xl text-brand-cream/80 font-light max-w-lg leading-relaxed"
      >
        {subtitle}
      </p>
      <div class="flex flex-wrap gap-6 pt-4">
        <a
          class="px-10 py-5 bg-brand-cream text-brand-dark rounded-full font-label font-bold text-sm uppercase tracking-widest hover:scale-105 transition-transform shadow-2xl"
          href={primaryCta.href}
        >
          {primaryCta.label}
        </a>
        <a
          class="px-10 py-5 border border-brand-cream/30 text-brand-cream rounded-full font-label font-bold text-sm uppercase tracking-widest hover:bg-white/10 transition-all"
          href={secondaryCta.href}
        >
          {secondaryCta.label}
        </a>
      </div>
    </div>
    <div class="lg:col-span-6 relative">
      <div
        class="relative w-full aspect-[4/5] rounded-[2rem] overflow-hidden shadow-2xl rotate-2"
      >
        <img
          alt={heroImageAlt}
          class="w-full h-full object-cover"
          src={heroImageUrl}
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-brand-dark/60 to-transparent"
        >
        </div>
      </div>
      <div
        class="absolute -bottom-10 -left-10 md:-left-20 p-8 bg-brand-cream rounded-full shadow-2xl max-w-xs rotate-[-3deg] border border-outline-variant/10 text-brand-dark"
      >
        <MaterialIcon
          name={floatingCard.icon}
          class="text-tertiary text-4xl mb-4"
          fill
        />
        <h3 class="font-headline text-2xl text-primary font-bold mb-2">
          {floatingCard.title}
        </h3>
        <p class="text-sm text-on-surface-variant leading-relaxed">
          {floatingCard.body}
        </p>
      </div>
    </div>
  </div>
  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-[0]">
    <svg
      class="relative block w-full h-20"
      preserveAspectRatio="none"
      viewBox="0 0 1200 120"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        class="fill-surface-container-highest/30"
        d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C58.47,88.59,127.88,83.06,197,80.4,248.6,78.41,281.24,63.9,321.39,56.44Z"
      ></path>
    </svg>
  </div>
</section>
