---
interface GalleryImage {
  url: string;
  alt: string;
}

interface Props {
  title: string;
  images: GalleryImage[];
}

const { title, images } = Astro.props;
---

<section class="bg-surface text-on-surface" id="galeria">
  <h2 class="sr-only">{title}</h2>
  <div class="grid grid-cols-1 md:grid-cols-3">
    {images.map((img) => (
      <img
        alt={img.alt}
        class="block w-full aspect-square object-cover"
        loading="lazy"
        src={img.url}
      />
    ))}
  </div>
</section>
