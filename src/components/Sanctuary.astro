---
import MaterialIcon from "./MaterialIcon.astro";

interface SanctuaryImage {
  url: string;
  alt: string;
}

interface Props {
  title: string;
  intro: string;
  rules: string[];
  images: SanctuaryImage[];
}

const { title, intro, rules, images } = Astro.props;

const imageStyles = [
  "aspect-square rounded-full overflow-hidden border-8 border-surface-container-high shadow-inner",
  "aspect-square rounded-full overflow-hidden border-8 border-surface-container-high shadow-inner mt-12",
  "aspect-square rounded-full overflow-hidden border-8 border-surface-container-high shadow-inner hidden md:block",
];

const imgClasses = [
  "w-full h-full object-cover grayscale opacity-80",
  "w-full h-full object-cover",
  "w-full h-full object-cover grayscale",
];
---

<section class="py-20 overflow-hidden relative">
  <div
    class="absolute left-0 right-0 h-32 bg-surface-container rotate-1 -z-10"
  >
  </div>
  <div class="max-w-7xl mx-auto px-8">
    <div class="flex flex-col md:flex-row gap-12 items-center">
      <div class="md:w-1/3">
        <h3
          class="text-3xl font-headline font-bold text-secondary mb-6 tracking-tight"
        >
          {title}
        </h3>
        <p class="text-on-surface-variant mb-8">{intro}</p>
        <ul class="space-y-4">
          {
            rules.map((rule) => (
              <li class="flex items-center gap-3 text-primary font-medium">
                <MaterialIcon name="check_circle" class="text-tertiary" />
                {rule}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="md:w-2/3 grid grid-cols-2 md:grid-cols-3 gap-4">
        {
          images.map((img, i) => (
            <div class={imageStyles[i] ?? imageStyles[0]}>
              <img
                alt={img.alt}
                class={imgClasses[i] ?? imgClasses[0]}
                src={img.url}
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
