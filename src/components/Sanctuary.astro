---
import MaterialIcon from "./MaterialIcon.astro";

interface SanctuaryImage {
  url: string;
  alt: string;
}

interface Props {
  title: string;
  intro: string;
  items: string[];
  images: SanctuaryImage[];
}

const { title, intro, items, images } = Astro.props;

const imageStyles = [
  "aspect-square rounded-full overflow-hidden border-8 border-surface-container-high shadow-inner",
  "aspect-square rounded-full overflow-hidden border-8 border-surface-container-high shadow-inner mt-12",
  "aspect-square rounded-full overflow-hidden border-8 border-surface-container-high shadow-inner hidden md:block",
];
---

<section class="py-20 overflow-hidden relative text-on-background" id="mision">
  <div class="max-w-7xl mx-auto px-8">
    <div class="flex flex-col md:flex-row gap-12 items-center">
      <div class="md:w-1/3">
        <h3
          class="text-5xl font-headline font-bold text-secondary-fixed mb-6 tracking-tight"
        >
          {title}
        </h3>
        <p class="text-on-background/90 mb-8">{intro}</p>
        <ul class="space-y-4">
          {
            items.map((item) => (
              <li class="flex items-center gap-3 text-on-background font-medium">
                <MaterialIcon name="check_circle" class="text-tertiary" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="md:w-2/3 grid grid-cols-2 md:grid-cols-3 gap-4">
        {
          images.map((img, i) => (
            <div class={imageStyles[i] ?? imageStyles[0]}>
              <img
                alt={img.alt}
                class="w-full h-full object-cover"
                src={img.url}
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
