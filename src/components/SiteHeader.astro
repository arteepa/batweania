---
import MaterialIcon from "./MaterialIcon.astro";

interface NavItem {
  label: string;
  href: string;
  style: "default" | "emphasis";
}

interface Props {
  siteName: string;
  logoIcon: string;
  navItems: NavItem[];
}

const { siteName, logoIcon, navItems } = Astro.props;
---

<header
  class="w-full sticky top-0 z-40 bg-brand-dark/90 backdrop-blur-md shadow-[0_24px_48px_-12px_rgba(32,27,13,0.3)]"
>
  <div class="flex justify-between items-center px-8 py-6 max-w-7xl mx-auto">
    <div class="flex items-center gap-3">
      <MaterialIcon name={logoIcon} class="text-tertiary-fixed text-3xl" />
      <span
        class="text-2xl font-headline font-semibold text-brand-cream tracking-tighter"
      >
        {siteName}
      </span>
    </div>
    <nav id="desktop-nav" class="hidden md:flex gap-10 items-center">
      {
        navItems.map((item, i) =>
          item.style === "emphasis" ? (
            <a
              class="px-6 py-2 bg-brand-cream text-brand-dark rounded-full font-label text-sm uppercase tracking-widest hover:bg-white transition-all"
              href={item.href}
            >
              {item.label}
            </a>
          ) : (
            <a
              class:list={[
                "transition-colors duration-500",
                i === 0
                  ? "text-tertiary-fixed border-b-2 border-tertiary-fixed font-medium py-1"
                  : "text-brand-cream opacity-80 hover:text-tertiary-fixed",
              ]}
              href={item.href}
            >
              {item.label}
            </a>
          ),
        )
      }
    </nav>
    <button id="mobile-menu-btn" class="md:hidden text-brand-cream">
      <MaterialIcon name="menu" class="text-3xl" />
    </button>
  </div>

  <nav
    id="mobile-nav"
    class="hidden md:hidden flex-col gap-4 px-8 pb-6 items-start"
  >
    {
      navItems.map((item) =>
        item.style === "emphasis" ? (
          <a
            class="px-6 py-2 bg-brand-cream text-brand-dark rounded-full font-label text-sm uppercase tracking-widest"
            href={item.href}
          >
            {item.label}
          </a>
        ) : (
          <a
            class="text-brand-cream opacity-80 hover:text-tertiary-fixed transition-colors duration-500"
            href={item.href}
          >
            {item.label}
          </a>
        ),
      )
    }
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const nav = document.getElementById("mobile-nav");
  btn?.addEventListener("click", () => {
    nav?.classList.toggle("hidden");
    nav?.classList.toggle("flex");
  });
</script>
