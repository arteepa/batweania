---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import FeaturedImage from "@/components/FeaturedImage.astro";
import Mission from "@/components/Mission.astro";
import Sanctuary from "@/components/Sanctuary.astro";
import Logros from "@/components/Logros.astro";
import Contribute from "@/components/Contribute.astro";
import Gallery from "@/components/Gallery.astro";
import Contact from "@/components/Contact.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import {
  sanityFetch,
  urlFor,
  homePageQuery,
  siteSettingsQuery,
  type HomePageDoc,
  type SiteSettingsDoc,
} from "@/lib/sanity";

const settings = await sanityFetch<SiteSettingsDoc>(siteSettingsQuery);
const page = await sanityFetch<HomePageDoc>(homePageQuery);

const defaultSettings: SiteSettingsDoc = {
  siteName: "Batwe Ania",
  logoIcon: "flutter_dash",
  navItems: [
    { label: "Misión", href: "#mision", style: "default" },
    { label: "Logros", href: "#logros", style: "default" },
    { label: "Voluntariado", href: "#ayuda", style: "default" },
    { label: "Fotos", href: "#galeria", style: "default" },
    { label: "Contáctanos", href: "#contacto", style: "emphasis" },
  ],
  footerLinks: [],
  socialLinks: [],
  footerCredit: {
    prefix: "website donado por",
    linkLabel: "tiemposmejores.org",
    linkUrl: "https://tiemposmejores.org",
  },
};

const s = settings ?? defaultSettings;

const featuredFallback = {
  imageUrl: "/batweania-hero.jpg",
  imageAlt: "Paisaje Natural en Batwe Ania",
};

const featured = page?.featuredImage?.asset
  ? {
      imageUrl: urlFor(page.featuredImage).width(1500).url(),
      imageAlt: page.featuredImage.alt ?? featuredFallback.imageAlt,
    }
  : featuredFallback;

const heroFallback = {
  subtitle:
    'Un proyecto comunitario que busca establecer el primer parque natural de Cajeme.<br /><br />"Batwe Ania" significa "Universo del Río" en lengua Yoeme Yaqui.',
  primaryCta: { label: "Únete al Voluntariado", href: "#ayuda" },
  secondaryCta: { label: "Conoce Nuestra Misión", href: "#mision" },
};

const hero = page?.hero
  ? {
      subtitle: page.hero.subtitle,
      primaryCta: page.hero.primaryCta,
      secondaryCta: page.hero.secondaryCta,
    }
  : heroFallback;

const missionFallback = {
  headline: "¿Por qué aquí?",
  body: "En el pueblo de Los Hornos, se encuentra el inicio y final del Río Yaqui, y su riqueza natural justifica el proyecto: El último sistema ripario y última selva baja caducifolia que queda del Río Yaqui. Punto clave en el sur de Sonora para anidación de aves y biodiversidad.",
};

const mission = page?.mission
  ? { headline: page.mission.headline, body: page.mission.body }
  : missionFallback;

const sanctuaryFallbackImages = [
  { url: "/mision/mision-1.jpg", alt: "Textura de corteza de árbol" },
  { url: "/mision/mision-2.jpg", alt: "Hojas verdes" },
  { url: "/mision/mision-3.jpg", alt: "Montañas lejanas" },
];

const sanctuaryFallback = {
  title: "Misión",
  intro:
    "La riqueza no solo está en la naturaleza sino en las personas y el vínculo colaborativo.",
  items: [
    "Sensibilizar a nuevas generaciones y reconectar con las raíces.",
    "Crear un puente entre la cosmovisión Yoeme Yaqui y los nuevos actores.",
    "Hacer un pueblo más habitable y feliz.",
    "Que sea sostenible por la misma comunidad.",
  ],
  images: sanctuaryFallbackImages,
};

const sanctuary = page?.sanctuary
  ? {
      title: page.sanctuary.title,
      intro: page.sanctuary.intro,
      items: page.sanctuary.items,
      images:
        page.sanctuary.images?.map((img) => ({
          url: img.asset ? urlFor(img).width(600).url() : "",
          alt: img.alt ?? "",
        })) ?? sanctuaryFallback.images,
    }
  : sanctuaryFallback;

const logrosFallback = {
  title: "¿Qué hemos logrado?",
  intro: "Los logros concretos del proyecto hasta ahora:",
  items: [
    "Rehabilitación del centro de salud del pueblo.",
    "Rehabilitación de áreas verdes y reforestación.",
    "Vivero comunitario.",
    "Talleres gratuitos (etnobotánica, meditación, avistamiento de aves, danza).",
    "Eventos culturales.",
    "Murales de biodiversidad y cosmovisión Yaqui en el corredor principal por artistas locales.",
  ],
};

const logros = page?.logros
  ? {
      title: page.logros.title ?? logrosFallback.title,
      intro: page.logros.intro ?? logrosFallback.intro,
      items:
        (page.logros.items?.filter(Boolean).length ?? 0) > 0
          ? page.logros.items!
          : logrosFallback.items,
    }
  : logrosFallback;

const contributeFallback = {
  title: "Súmate al Voluntariado",
  intro: "No se necesita experiencia, solo ganas de hacer algo por la tierra.",
  body: "Estamos creando el primer sendero ecológico del Parque Batwe Ania y necesitamos tus manos para hacerlo realidad.<br /><br />Nos coordinamos a través de un grupo de WhatsApp donde compartimos las necesidades del proyecto y organizamos las jornadas de trabajo.",
  ctaLabel: "Únete al grupo de WhatsApp",
  ctaHref: "https://chat.whatsapp.com/D60IopcvQqTF8X8RU4KcgU?mode=gi_t",
};

const contribute = page?.contribute
  ? {
      title: page.contribute.title,
      intro: page.contribute.intro,
      body: page.contribute.body,
      ctaLabel: page.contribute.ctaLabel,
      ctaHref: page.contribute.ctaHref,
    }
  : contributeFallback;

const localGalleryImages = [
  { url: "/fotos/1.jpeg", alt: "Galería Batwe Ania 1" },
  { url: "/fotos/2.jpeg", alt: "Galería Batwe Ania 2" },
  { url: "/fotos/3.jpeg", alt: "Galería Batwe Ania 3" },
  { url: "/fotos/4.jpeg", alt: "Galería Batwe Ania 4" },
  { url: "/fotos/5.jpeg", alt: "Galería Batwe Ania 5" },
  { url: "/fotos/6.jpeg", alt: "Galería Batwe Ania 6" },
  { url: "/fotos/7.jpeg", alt: "Galería Batwe Ania 7" },
  { url: "/fotos/8.jpeg", alt: "Galería Batwe Ania 8" },
];

const gallery = {
  title: page?.gallery?.title ?? "Fotos",
  images: localGalleryImages,
};

const contactFallback = {
  title: "Contáctanos",
  intro:
    "¿Deseas organizar una visita escolar, un retiro de investigación o simplemente saber más sobre nuestro trabajo? Escríbenos por Instagram.",
  instagramUrl: "https://www.instagram.com/parque.batweania/",
  instagramHandle: "@parque.batweania",
};

const contact = page?.contact
  ? {
      title: page.contact.title,
      intro: page.contact.intro,
      instagramUrl: page.contact.instagramUrl ?? contactFallback.instagramUrl,
      instagramHandle:
        page.contact.instagramHandle ?? contactFallback.instagramHandle,
    }
  : contactFallback;

const footerCredit = s.footerCredit ?? {
  prefix: "website donado por",
  linkLabel: "tiemposmejores.org",
  linkUrl: "https://tiemposmejores.org",
};
---

<BaseLayout>
  <main>
    <Hero {...hero} />
    <FeaturedImage {...featured} />
    <Mission {...mission} />
    <Sanctuary {...sanctuary} />
    <Logros {...logros} />
    <Contribute {...contribute} />
    <Gallery {...gallery} />
    <Contact {...contact} />
  </main>
  <SiteFooter
    creditPrefix={footerCredit.prefix}
    creditLinkLabel={footerCredit.linkLabel}
    creditLinkHref={footerCredit.linkUrl}
  />
</BaseLayout>
