---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import Mission from "@/components/Mission.astro";
import Sanctuary from "@/components/Sanctuary.astro";
import TrailMap from "@/components/TrailMap.astro";
import Contribute from "@/components/Contribute.astro";
import Gallery from "@/components/Gallery.astro";
import Contact from "@/components/Contact.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import {
  sanityFetch,
  urlFor,
  homePageQuery,
  siteSettingsQuery,
  type HomePageDoc,
  type SiteSettingsDoc,
} from "@/lib/sanity";

const settings = await sanityFetch<SiteSettingsDoc>(siteSettingsQuery);
const page = await sanityFetch<HomePageDoc>(homePageQuery);

// ── Fallback data used when Sanity has no content yet ──

const defaultSettings: SiteSettingsDoc = {
  siteName: "BATWE ANIA",
  logoIcon: "flutter_dash",
  navItems: [
    { label: "Misión", href: "#mision", style: "default" },
    { label: "Sendero", href: "#mapa", style: "default" },
    { label: "Contribuir", href: "#ayuda", style: "default" },
    { label: "Galería", href: "#galeria", style: "default" },
    { label: "Visítanos", href: "#contacto", style: "emphasis" },
  ],
  footerLinks: [
    { label: "Sacred Lands", href: "#" },
    { label: "Community", href: "#" },
    { label: "Conservation", href: "#" },
  ],
  socialLinks: [
    { icon: "public", href: "#" },
    { icon: "diversity_3", href: "#" },
    { icon: "spa", href: "#" },
  ],
  copyrightLine: "© Batwe Ania Ecological Park. Rooted in Yoeme Yaqui Heritage.",
};

const s = settings ?? defaultSettings;

const heroFallback = {
  titlePlain: "Parque Natural",
  titleItalic: "Batwe Ania",
  subtitle: "Bienvenido a Batwe Ania. Un santuario donde la tierra cuenta historias ancestrales y el agua nutre el alma de nuestra comunidad.",
  primaryCta: { label: "Explorar Tierras", href: "#ayuda" },
  secondaryCta: { label: "Nuestra Misión", href: "#mision" },
  heroImageUrl: "https://lh3.googleusercontent.com/aida-public/AB6AXuCjN0Uv5FcBzPgHpdnGsfcRuXw55732BPGaO5Ej_7RTMzv3tUI-A_isUjmg2CjlSdiXWmF4SkdangeiSCsEjR9j_pBest9TDk2giFm2cc9Lvk0tFpWx7QRzWv4KIA6SXLo-EeVpBK_8oJrHT-arGlBKoqSvuDTr3cbn_HPQfD3ZAMHJrFyNWO4WNqoBSqNIQCLFVTct1Cux2su5IIhU0bkcb9acOHfhMETwoH8fRcqORQWsXUV-8N6VL4wzq2ZoSe9CIQ1mu9yXjjhw",
  heroImageAlt: "Bosque denso con luz solar filtrada",
  floatingCard: { icon: "waves", title: "Aguas Sagradas", body: "Protegemos el ecosistema ribereño bajo los principios de reciprocidad Yoeme." },
};

const hero = page?.hero
  ? {
      titlePlain: page.hero.titlePlain,
      titleItalic: page.hero.titleItalic,
      subtitle: page.hero.subtitle,
      primaryCta: page.hero.primaryCta,
      secondaryCta: page.hero.secondaryCta,
      heroImageUrl: page.hero.heroImage?.asset
        ? urlFor(page.hero.heroImage).width(1200).url()
        : heroFallback.heroImageUrl,
      heroImageAlt: page.hero.heroImage?.alt ?? heroFallback.heroImageAlt,
      floatingCard: page.hero.floatingCard,
    }
  : heroFallback;

const missionFallback = {
  icon: "nature",
  headline: "Cuidar la vida para que la vida nos cuide.",
  quote: "Batwe Ania no es solo un parque; es la manifestación física de nuestra cosmovisión. Aquí, cada árbol de mezquite y cada piedra en el cauce tiene una voz que respetamos y preservamos para las generaciones venideras.",
  body: "Nuestra misión es la restauración ecológica integral del territorio Yaqui, fusionando el conocimiento botánico tradicional con la conservación científica moderna. Buscamos devolverle al río su flujo natural y a nuestra gente su conexión sagrada con el entorno.",
};

const mission = page?.mission ?? missionFallback;

const sanctuaryFallbackImages = [
  { url: "https://lh3.googleusercontent.com/aida-public/AB6AXuDU67CDR6WoJQwpADsZtN6E4bpAraQLuEE3EGUE-ljEXvqROSiAl0fIQH6gpBue9uReaTSyiNieLdugBhVU9jeApjm2O_PXWvdGGUqqd1fMWr0TCPzpyOW9LN9TxcCdvYhvT9VqhdEKUpb1JJs-cgc2pBe5YGBH7WqQXDrehMEDDCfb6xug2FUCKw25fMk3BAeZ_wgXwMWLzQwCabNfFC7AYAHbmUM6sDtFdc6vY5FUnQuhnBcyO1bh9Us3nso4RAK9d71rPGBVKqql", alt: "Textura de corteza de árbol" },
  { url: "https://lh3.googleusercontent.com/aida-public/AB6AXuDVM0jb9eYLH_EzihbXBp5pSNvLXv4BdcfvAWUV3yfX4P40-lxmaZvHWabSWW7G6soByRcwBZY2AmO86P_DnL6NCABdMUoUSaUXUdop33WPG-yhrhoEkFJNyddshAeBj67OUKJJJ_F_GqRhnS9zlDA6SsfMvt1Pj_BwLbKW7fMFx9Et653jDF8BxBVy6lXYADsCuXwzO7emj6EEH1tWxfTpk-qjOR8w0jGpX90Ev4q5qe9qd4gukv0hN-dRo63AFSas1573aiC3fwfV", alt: "Hojas verdes" },
  { url: "https://lh3.googleusercontent.com/aida-public/AB6AXuC7UEhWC-VIVyJHfXkYI-RMiHXVIL5PKW7AXolvGTSFoAP8scnQItq4WXHetizerySIMO5GA-NINvgV6foJw2hhHogJrOuE-hTHmtiaQOEfc7fKiikp7Vx2nD8Pshb7EIAUgOeyL5U6CjSLFNp3Zt9nYpx-d6eF_oSlhFsAtqtni_C3bFvotcWTjXNXMJg40ymOHq4LJxjfBLgubkiU8t-m4V8ovqseOwlIqSJ8c6DhsqfwLpSkgid1gGXAc2HXeCs1y_wncFmdG1XZ", alt: "Montañas lejanas" },
];

const sanctuaryFallback = {
  title: "Respeto al Santuario",
  intro: "Caminamos con ligereza. El parque es un ser vivo que requiere nuestro cuidado colectivo.",
  rules: ["Solo huellas, nada de basura.", "Silencio en las zonas de anidación.", "Respeto a la flora nativa."],
  images: sanctuaryFallbackImages,
};

const sanctuary = page?.sanctuary
  ? {
      title: page.sanctuary.title,
      intro: page.sanctuary.intro,
      rules: page.sanctuary.rules,
      images: page.sanctuary.images?.map((img) => ({
        url: img.asset ? urlFor(img).width(600).url() : "",
        alt: img.alt ?? "",
      })) ?? sanctuaryFallback.images,
    }
  : sanctuaryFallback;

const trailFallback = {
  title: "El Sendero de la Vida.",
  intro: "Un mapa diseñado para guiarte por los puntos más sagrados y biodiversos de nuestra reserva.",
  mapImageUrl: "https://lh3.googleusercontent.com/aida-public/AB6AXuDaiFrpwrctAJxUVbhmSqxvJps9OKyg1tiFKApmVbE-w-oiDl_1o8PA0-oB40iDYnf2Lou83N6cwSfdXt9Je00Iz3fNirMODSor4RGfB9JFjAVAk_5NcI2OfnTzyKBKN-bIRbM9NSRbuDDCdlAEwYehAs2bbWV9rD_9ETfDPCQEt46n95xuNDs2OxkMM6Nzypcm-dLH1YtH87Ebl2FOeiIjlNQVs87i2Ya4cQRQDyM9PaS1hUk1Ot8ritxs7FYboSpX5rf0JS_ytTx9",
  mapImageAlt: "Mapa ilustrado del sendero",
  featuredRoute: { title: "Ruta Ancestral", meta: "12km · Dificultad Media" },
  bentoTiles: [
    { _type: "observation" as const, title: "Punto de Observación", body: "Avistamiento de aves migratorias y flora endémica.", icon: "visibility" },
    { _type: "stat" as const, value: "8", label: "Estaciones" },
    { _type: "iconCallout" as const, icon: "explore", label: "Guías Locales" },
  ],
};

const trail = page?.trail
  ? {
      title: page.trail.title,
      intro: page.trail.intro,
      mapImageUrl: page.trail.mapImage?.asset
        ? urlFor(page.trail.mapImage).width(1200).url()
        : trailFallback.mapImageUrl,
      mapImageAlt: page.trail.mapImage?.alt ?? trailFallback.mapImageAlt,
      featuredRoute: page.trail.featuredRoute,
      bentoTiles: page.trail.bentoTiles,
    }
  : trailFallback;

const contributeFallback = {
  title: "Formas de Tejido Comunitario.",
  intro: "Tu apoyo permite que el ciclo de la vida continúe en Batwe Ania.",
  cards: [
    { icon: "volunteer_activism", title: "Voluntariado", body: "Únete a nuestras jornadas de reforestación y limpieza del cauce del río cada primer sábado del mes.", ctaLabel: "Inscríbete", ctaHref: "#" },
    { icon: "shopping_bag", title: "Artesanía Local", body: "Adquiere productos creados por artesanos de la comunidad. El 100% vuelve a la conservación.", ctaLabel: "Ver Tienda", ctaHref: "#" },
    { icon: "favorite", title: "Donaciones", body: "Tu contribución económica directa apoya la investigación científica y la protección de fauna nativa.", ctaLabel: "Donar Ahora", ctaHref: "#" },
  ],
};

const contribute = page?.contribute ?? contributeFallback;

const galleryFallbackImages = [
  { url: "https://lh3.googleusercontent.com/aida-public/AB6AXuDSFqr6-E-3M0LNu65xzYQ2ig6kDVyVOfA0NfV0esAIqC2-z4QIAY0Sm1K5i7iyeDDusY1r7dnih5BQLgpiG0QtpF9evTbYZ32TdnKptxaZUcUAG5DQp6P1qjchrxkYmT7QzpNsLXUy6UjuAGyUJrbvgH5VtdwKuChllThtsFgqYQ40pNrXwKOPQAeC_sVA6zVfNfYhyzix_5vmRWemtCN6uKbWGud59wq12ZhB2Ihp3fvKWGbR6i8boyrdWOwife1tYGCXKqFAKhM1", alt: "Vista del río" },
  { url: "https://lh3.googleusercontent.com/aida-public/AB6AXuArzUnZcETkmE90qr7k0rdG7RmfsTXnzuNPnA8d-vWSQ1l-kZLEr-7btbKJ_7IxL21nGIPip-iXRY_7ZuFmVD8G7iFZvUp6FqVJr-ikeGnZP0ZSqrbNzdxGvyyvxbLKQZobo_nVzIDgSp5PFeJaU4p-tTshkekdGbp91AfvSSXQbG1gUDfGhgSL_8jeXPXam6YP0QfEA7ORkVMo1oq2Ir1CF5kSQo7picb_HU9iLoQPdaVdH65PmKr8Mm6WDl4Cz1vnn8OuKZvOOywH", alt: "Cascada oculta" },
