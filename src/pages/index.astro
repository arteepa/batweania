  { url: "https://lh3.googleusercontent.com/aida-public/AB6AXuDnMKb6_YunBbL3C1ngmtjOQTgOGmm17ELK_HErC3xQ2lLP8KFhIkT5nFLzxktoV9vityktnoRunyAO3wmrL4_sCUkZYhX6QYitgu8pobcCzqbpIpZ6G31JU4I4Tz38TjuWWsX_vh91oH6OzJVID-lBc4hVc6IoBhBHT71VYpn8UZliE5L5tLn6Sx5xxMtwmIHbtTc1pdn7CE5rl3T_VKSiPR0SteY5FzHwYK6Tj9hkIExuWc04fGrlcFJgW7VFIUd50kb8H7m0IrOQ", alt: "Refugio natural" },
