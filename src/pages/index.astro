    {
      icon: "volunteer_activism",
      title: "Voluntariado",
      body: "Únete a nuestras jornadas de reforestación y limpieza del cauce del río cada primer sábado del mes.",
      ctaLabel: "Inscríbete",
      ctaHref: "#",
    },
    {
      icon: "shopping_bag",
      title: "Merch",
      body: "Adquiere productos de Batwe Ania. Las ganancias son invertidas en el parque.",
      ctaLabel: "Ver Tienda",
      ctaHref: "#",
    },
    {
      icon: "favorite",
      title: "Donaciones",
      body: "Tu contribución económica directa apoya la investigación científica y la protección de fauna nativa.",
      ctaLabel: "Donar Ahora",
      ctaHref: "#",
    },
  ],
};

