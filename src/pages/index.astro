---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import FeaturedImage from "@/components/FeaturedImage.astro";
import Mission from "@/components/Mission.astro";
import Sanctuary from "@/components/Sanctuary.astro";
import TrailMap from "@/components/TrailMap.astro";
import Contribute from "@/components/Contribute.astro";
import Gallery from "@/components/Gallery.astro";
import Contact from "@/components/Contact.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import {
  sanityFetch,
  urlFor,
  homePageQuery,
  siteSettingsQuery,
  type HomePageDoc,
  type SiteSettingsDoc,
} from "@/lib/sanity";

const settings = await sanityFetch<SiteSettingsDoc>(siteSettingsQuery);
const page = await sanityFetch<HomePageDoc>(homePageQuery);

const defaultSettings: SiteSettingsDoc = {
  siteName: "Batwe Ania",
  logoIcon: "flutter_dash",
  navItems: [
    { label: "Misión", href: "#mision", style: "default" },
    { label: "Reglamento", href: "#reglamento", style: "default" },
    { label: "Senderos", href: "#mapa", style: "default" },
    { label: "¿Cómo aportar?", href: "#ayuda", style: "default" },
    { label: "Fotos", href: "#galeria", style: "default" },
    { label: "Contáctanos", href: "#contacto", style: "emphasis" },
  ],
  footerLinks: [],
  socialLinks: [],
  footerCredit: {
    prefix: "Website x",
    linkLabel: "Tiempos Mejores",
    linkUrl: "https://tiemposmejores.org",
  },
};

const s = settings ?? defaultSettings;

const featuredFallback = {
  imageUrl:
    "https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=1500&q=80",
  imageAlt: "Paisaje Natural en Batwe Ania",
};

const featured = page?.featuredImage?.asset
  ? {
      imageUrl: urlFor(page.featuredImage).width(1500).url(),
      imageAlt: page.featuredImage.alt ?? featuredFallback.imageAlt,
    }
  : featuredFallback;

const heroFallback = {
  titlePlain: "Parque Natural",
  titleItalic: "Batwe Ania",
  subtitle:
    "En el pueblo de Los Hornos se encuentra el inicio y final del Río Yaqui.\n\nUn lugar lleno de vida que merece ser cuidado.",
  primaryCta: { label: "Visita el Parque", href: "#ayuda" },
  secondaryCta: { label: "Nuestra Misión", href: "#mision" },
};

const hero = page?.hero
  ? {
      titlePlain: page.hero.titlePlain,
      titleItalic: page.hero.titleItalic,
      subtitle: page.hero.subtitle,
      primaryCta: page.hero.primaryCta,
      secondaryCta: page.hero.secondaryCta,
    }
  : heroFallback;

const missionFallback = {
  headline: "Nuestra Misión",
  quote:
    "Batwe Ania no es solo un parque; es la manifestación física de nuestra cosmovisión. Aquí, cada árbol de mezquite y cada piedra en el cauce tiene una voz que respetamos y preservamos para las generaciones venideras.",
  body: "Nuestra misión es la restauración ecológica integral del territorio Yaqui, fusionando el conocimiento botánico tradicional con la conservación científica moderna. Buscamos devolverle al río su flujo natural y a nuestra gente su conexión sagrada con el entorno.",
};

const mission = page?.mission ?? missionFallback;

