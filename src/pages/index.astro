const gallery = page?.gallery
  ? {
      title: page.gallery.title,
      images: page.gallery.images?.map((img) => ({
        url: img.asset ? urlFor(img).width(600).url() : "",
        alt: img.alt ?? "",
      })) ?? galleryFallbackImages,
    }
  : { title: "Fragmentos de Realidad.", images: galleryFallbackImages };

const contactFallback = {
  title: "Estamos aquí para escucharte.",
  intro: "¿Deseas organizar una visita escolar, un retiro de investigación o simplemente saber más sobre nuestro trabajo? Escríbenos.",
  locationLabel: "Ubicación",
  locationText: "Km 45, Carretera al Río Yaqui. Sonora, México.",
  emailLabel: "Correo Electrónico",
  emailAddress: "contacto@batweania.org",
  formLabels: { name: "Nombre Completo", email: "Correo Electrónico", message: "Mensaje", submit: "Enviar Mensaje" },
};

const contact = page?.contact
  ? {
      title: page.contact.title,
      intro: page.contact.intro,
      locationLabel: page.contact.location?.label ?? contactFallback.locationLabel,
      locationText: page.contact.location?.text ?? contactFallback.locationText,
      emailLabel: page.contact.email?.label ?? contactFallback.emailLabel,
      emailAddress: page.contact.email?.address ?? contactFallback.emailAddress,
      formLabels: page.contact.formLabels ?? contactFallback.formLabels,
    }
  : contactFallback;
---

<BaseLayout>
  <main>
    <Hero {...hero} />
    <Mission {...mission} />
    <Sanctuary {...sanctuary} />
    <TrailMap {...trail} />
    <Contribute {...contribute} />
    <Gallery {...gallery} />
    <Contact {...contact} />
  </main>
  <SiteFooter
    siteName={s.siteName}
    logoIcon={s.logoIcon}
    footerLinks={s.footerLinks}
    socialLinks={s.socialLinks}
    copyrightLine={s.copyrightLine}
  />
</BaseLayout>
