const gallery = page?.gallery
  ? {
      title: page.gallery.title,
      images:
        page.gallery.images?.map((img) => ({
          url: img.asset ? urlFor(img).width(600).url() : "",
          alt: img.alt ?? "",
        })) ?? galleryFallbackImages,
    }
  : { title: "Fotos", images: galleryFallbackImages };

const contactFallback = {
  title: "Contáctanos",
  intro:
    "¿Deseas organizar una visita escolar, un retiro de investigación o simplemente saber más sobre nuestro trabajo? Escríbenos.",
  locationLabel: "Ubicación",
  locationText: "Km 45, Carretera al Río Yaqui. Sonora, México.",
  emailLabel: "Correo Electrónico",
  emailAddress: "contacto@batweania.org",
};

const contact = page?.contact
  ? {
      title: page.contact.title,
      intro: page.contact.intro,
      locationLabel: page.contact.location?.label ?? contactFallback.locationLabel,
      locationText: page.contact.location?.text ?? contactFallback.locationText,
      emailLabel: page.contact.email?.label ?? contactFallback.emailLabel,
      emailAddress: page.contact.email?.address ?? contactFallback.emailAddress,
    }
  : contactFallback;

const footerCredit = s.footerCredit ?? {
  prefix: "Website x",
  linkLabel: "Tiempos Mejores",
  linkUrl: "https://tiemposmejores.org",
};
---

<BaseLayout>
  <main>
    <Hero {...hero} />
    <FeaturedImage {...featured} />
    <Mission {...mission} />
    <Sanctuary {...sanctuary} />
    <TrailMap {...trail} />
    <Contribute {...contribute} />
    <Gallery {...gallery} />
    <Contact {...contact} />
  </main>
  <SiteFooter
    siteName={s.siteName}
    logoIcon={s.logoIcon}
    creditPrefix={footerCredit.prefix}
    creditLinkLabel={footerCredit.linkLabel}
    creditLinkHref={footerCredit.linkUrl}
  />
</BaseLayout>
